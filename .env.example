# PHeRef Web Portal environment configuration.
# Copy this file to `.env` and adjust values. All values can also be changed at
# runtime through the in-app Admin portal (/admin), which persists overrides to
# config/runtime-config.json.

# --- FHIR servers -----------------------------------------------------------
# Transactional server: stores/retrieves all eReferral + clinical resources.
PHEREF_FHIR_BASE_URL=https://cdr.pheref.fhirlab.net/fhir
# Terminology server (Ontoserver): ValueSet/$expand and CodeSystem/$lookup.
PHEREF_TERMINOLOGY_BASE_URL=https://tx.fhirlab.net/fhir

# --- PSA classification APIs ------------------------------------------------
PHEREF_PSA_BASE_URL=https://classification.psa.gov.ph
# PSGC version. Current public default Q4_2025; Connectathon target Q1_2026.
PHEREF_PSA_VERSION=Q4_2025
# Enable internal HUC handling rules (synthetic districts + HUC barangay filter behavior).
PHEREF_PSA_ENABLE_HUC_RULES=true
# PSA API access token (issued by PSA). Leave blank if not required.
PHEREF_PSA_TOKEN=

# --- Authentication ---------------------------------------------------------
# Optional bearer token sent to the FHIR transactional + terminology servers.
PHEREF_FHIR_AUTH_TOKEN=

# --- Networking -------------------------------------------------------------
PHEREF_HTTP_TIMEOUT=30
PHEREF_HOST=0.0.0.0
PHEREF_PORT=8000
